// ─── Prisma Generator ───────────────────────────────────────────────────────
generator client {
  provider = "prisma-client-js"
}

// ─── Datasource ──────────────────────────────────────────────────────────────
// Supabase usa PgBouncer (connection pooler):
//   DATABASE_URL → puerto 6543, PgBouncer, para queries de la app en runtime
//   DIRECT_URL   → puerto 5432, conexión directa, SOLO para migraciones
//
// Prisma detecta automáticamente cuál usar:
//   - npx prisma db push / migrate dev  → usa DIRECT_URL
//   - Queries normales en la app        → usa DATABASE_URL
//
// IMPORTANTE: DATABASE_URL debe incluir ?pgbouncer=true&connection_limit=1
// IMPORTANTE: DIRECT_URL NO debe incluir parámetros de pgbouncer
datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id              String            @id @default(uuid())
  email           String            @unique
  password        String
  name            String
  phone           String?
  avatarUrl       String?
  dateOfBirth     DateTime?
  gender          String?   // male, female, other
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  lastLoginAt     DateTime?
  isActive        Boolean           @default(true)
  isVerified      Boolean           @default(false)

  // Relaciones con todos los módulos
  nutritionProfile NutritionProfile?
  trainingProfile  TrainingProfile?
  hydrationSetting HydrationSetting?
  notificationPref NotificationPreference?

  workoutLogs      WorkoutLog[]
  mealLogs         MealLog[]
  sleepLogs        SleepLog[]
  hydrationLogs    HydrationLog[]
  supplements      UserSupplement[]
  shoppingLists    ShoppingList[]
  achievements     Achievement[]
  notifications    Notification[]

  // Nutrición extendido
  mealPlans       MealPlan[]
  nutritionProgress NutritionProgress[]
  recipes         Recipe[]
  recipeReviews   RecipeReview[]
  recipeFavorites RecipeFavorite[]
  reminders       NutritionReminder[]
  foodItems       FoodItem[]

  // Entrenamiento extendido
  trainingPlans   TrainingPlan[]
  exercises       Exercise[]
  trainingReminders TrainingReminder[]
  personalRecords PersonalRecord[]
  trainingProgress TrainingProgress[]

  // Hydration
  hydrationGoal       HydrationGoal?
  hydrationReminders  HydrationReminder[]
  hydrationSymptoms   HydrationSymptom[]
  hydrationChallenges UserChallenge[]
  hydrationAchievements HydrationAchievement[]
  hydrationWeather    WeatherData[]

  // Recovery
  sleepRecommendations SleepRecommendation[]
  relaxationLogs       RelaxationLog[]
  stressLogs           StressLog[]
  recoveryScores       RecoveryScore[]
  stretchingLogs       StretchingLog[]
  recoveryToolLogs     RecoveryToolLog[]
  deloadWeeks          DeloadWeek[]
  recoveryReminders    RecoveryReminder[]
  wearableData         WearableData[]

  // Shopping / Pantry
  pantryItems          PantryItem[]
  sharedShoppingLists  ShoppingListShare[]
  stores               Store[]
  purchaseHistories    PurchaseHistory[]
  shoppingReminders    ShoppingReminder[]

  // Supplements
  userStacks           UserStack[]
  supplementReminders  SupplementReminder[]
  supplementReviews    SupplementReview[]
  supplementPurchases  SupplementPurchase[]
  supplementLogs  SupplementLog[]


  // Notifications
  notificationTokens       NotificationToken[]
  notificationSchedules    NotificationSchedule[]
  notificationCampaigns    NotificationCampaign[]

  // Social
  socialPosts      SocialPost[]
  postLikes        PostLike[]
  postComments     PostComment[]
  following        UserFollow[]     @relation("Follower")
  followers        UserFollow[]     @relation("Following")
  bodyMeasurements BodyMeasurement[]

  // Phase 3 — Enterprise
  role               String   @default("user")

  // Phase 4 — AI + Wearables
  aiDailyUsage       Int      @default(0)
  aiDailyReset       DateTime?
  aiOptOut           Boolean  @default(false) // user can opt-out of AI features
  preferredAIModel   String?  // user's preferred AI model

  aiRecommendations  AIRecommendation[]
  chatMessages       ChatMessage[]
  wearableConnections WearableConnection[]
  stripeCustomerId   String?  @unique
  twoFASecret        String?
  twoFAEnabled       Boolean  @default(false)
  twoFABackupCodes   String[]
  isBanned           Boolean  @default(false)
  bannedAt           DateTime?
  bannedReason       String?

  subscription       UserSubscription?
  payments           Payment[]
  auditLogs          AuditLog[]
  supportTickets     SupportTicket[]
  supportReplies     SupportTicketReply[]

  // Phase 6 — Home Fitness
  trainer                    Trainer?
  classEnrollments           ClassEnrollment[]
  classReviews               ClassReview[]
  programEnrollments         ProgramEnrollment[]
  coachingSessions           CoachingSession[]
  progressPhotos             ProgressPhoto[]
  fitnessChallengeParticipants FitnessChallengeParticipant[]
  watchHistory               UserWatchHistory[]

  // Phase 7 — New Features
  userSettings               UserSettings?
  periodizedPlans            PeriodizedPlan[]
  formCheckSessions          FormCheckSession[]
  recoveryMetrics            RecoveryMetric[]
  mealDeliveryOrders         MealDeliveryOrder[]
  backups                    Backup[]
  importHistories            ImportHistory[]

  @@map("users")
  @@index([email])
  @@index([createdAt])
  @@index([role])
}

model NutritionProfile {
  id                   String   @id @default(uuid())
  userId               String   @unique
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  age                  Int
  gender               String
  weightKg             Decimal  @db.Decimal(5, 2)
  heightCm             Decimal  @db.Decimal(5, 2)
  activityLevel        String
  goal                 String
  bodyFatPercentage    Decimal? @db.Decimal(5, 2)
  trainingDaysPerWeek  Int?
  tmb                  Decimal? @db.Decimal(8, 2)
  tdee                 Decimal? @db.Decimal(8, 2)
  targetCalories       Int?
  targetProteinG       Int?
  targetCarbsG         Int?
  targetFatG           Int?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@map("nutrition_profiles")
}

model FoodItem {
  id             String   @id @default(uuid())
  userId         String?
  user           User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  name           String
  brand          String?
  category       String?
  caloriesPer100g Int
  proteinPer100g Decimal  @db.Decimal(8, 2)
  carbsPer100g   Decimal  @db.Decimal(8, 2)
  fatPer100g     Decimal  @db.Decimal(8, 2)
  fiberPer100g   Decimal? @db.Decimal(8, 2)
  servingSizeG   Int?
  servingUnit    String?
  barcode        String?  @unique
  isVerified     Boolean  @default(false)
  isCustom       Boolean  @default(false)
  createdAt      DateTime @default(now())
  mealLogs       MealLog[]
  recipeIngredients RecipeIngredient[]
  shoppingListItems ShoppingListItem[]
  pantryItems       PantryItem[]

  @@map("food_items")
}

model MealPlan {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String
  durationDays Int
  startDate    DateTime @db.Date
  endDate      DateTime @db.Date
  totalCalories Int?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  days         MealPlanDay[]
  mealPlanRecipes MealPlanRecipe[]

  @@map("meal_plans")
}

model MealPlanDay {
  id             String   @id @default(uuid())
  mealPlanId     String
  mealPlan       MealPlan @relation(fields: [mealPlanId], references: [id], onDelete: Cascade)
  dayNumber      Int
  date           DateTime? @db.Date
  totalCalories  Int?
  totalProteinG  Decimal? @db.Decimal(8, 2)
  totalCarbsG    Decimal? @db.Decimal(8, 2)
  totalFatG      Decimal? @db.Decimal(8, 2)
  isCompleted    Boolean  @default(false)
  meals          Meal[]

  @@map("meal_plan_days")
}

model Meal {
  id              String   @id @default(uuid())
  mealPlanDayId   String
  mealPlanDay     MealPlanDay @relation(fields: [mealPlanDayId], references: [id], onDelete: Cascade)
  mealType        String
  name            String
  calories        Int?
  proteinG        Decimal? @db.Decimal(8, 2)
  carbsG          Decimal? @db.Decimal(8, 2)
  fatG            Decimal? @db.Decimal(8, 2)
  fiberG          Decimal? @db.Decimal(8, 2)
  preparationTimeMinutes Int?
  difficultyLevel String?
  servings        Int      @default(1)
  instructions    String?  @db.Text
  imageUrl        String?
  isFavorite      Boolean  @default(false)
  createdAt       DateTime @default(now())

  @@map("meals")
}

model MealLog {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  foodItemId   String?
  foodItem     FoodItem? @relation(fields: [foodItemId], references: [id])
  mealType     String
  consumedAt   DateTime
  quantityG    Decimal  @db.Decimal(8, 2)
  calories     Int?
  proteinG     Decimal? @db.Decimal(8, 2)
  carbsG       Decimal? @db.Decimal(8, 2)
  fatG         Decimal? @db.Decimal(8, 2)
  satietyLevel Int?     // 1-5
  mood         String?
  location     String?
  photoUrl     String?
  notes        String?  @db.Text
  createdAt    DateTime @default(now())

  @@map("meal_logs")
}

model NutritionProgress {
  id                   String   @id @default(uuid())
  userId               String
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  loggedDate           DateTime @db.Date
  totalCalories        Int?
  totalProteinG        Decimal? @db.Decimal(8, 2)
  totalCarbsG          Decimal? @db.Decimal(8, 2)
  totalFatG            Decimal? @db.Decimal(8, 2)
  totalFiberG          Decimal? @db.Decimal(8, 2)
  waterIntakeMl        Int?
  weightKg             Decimal? @db.Decimal(5, 2)
  bodyFatPercentage    Decimal? @db.Decimal(5, 2)
  adherencePercentage  Decimal? @db.Decimal(5, 2)
  createdAt            DateTime @default(now())

  @@unique([userId, loggedDate])
  @@map("nutrition_progress")
}

model Recipe {
  id              String    @id @default(uuid())
  creatorId       String?
  creator         User?     @relation(fields: [creatorId], references: [id], onDelete: SetNull)
  name            String
  description     String?   @db.Text
  prepTimeMinutes Int?
  cookTimeMinutes Int?
  servings        Int
  difficultyLevel String?
  caloriesPerServing Int?
  proteinPerServing Decimal? @db.Decimal(8, 2)
  carbsPerServing  Decimal? @db.Decimal(8, 2)
  fatPerServing    Decimal? @db.Decimal(8, 2)
  fiberPerServing  Decimal? @db.Decimal(8, 2)
  imageUrl        String?
  videoUrl        String?
  isPublic        Boolean   @default(true)
  isVerified      Boolean   @default(false)
  ratingAvg       Decimal?  @db.Decimal(3, 2)
  ratingCount     Int       @default(0)
  createdAt       DateTime  @default(now())
  ingredients     RecipeIngredient[]
  instructions    RecipeInstruction[]
  reviews         RecipeReview[]
  favorites       RecipeFavorite[]
  tags            RecipeTag[]
  mealPlanRecipes MealPlanRecipe[]

  @@map("recipes")
}

model RecipeIngredient {
  id         String   @id @default(uuid())
  recipeId   String
  recipe     Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  foodItemId String?
  foodItem   FoodItem? @relation(fields: [foodItemId], references: [id])
  quantity   Decimal  @db.Decimal(8, 2)
  unit       String
  notes      String?

  @@map("recipe_ingredients")
}

model RecipeInstruction {
  id          String   @id @default(uuid())
  recipeId    String
  recipe      Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  stepNumber  Int
  instruction String   @db.Text
  imageUrl    String?

  @@map("recipe_instructions")
}

model RecipeReview {
  id          String   @id @default(uuid())
  recipeId    String
  recipe      Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  rating      Int
  comentario  String?  @db.Text
  createdAt   DateTime @default(now())

  @@map("recipe_reviews")
}

model RecipeFavorite {
  id          String   @id @default(uuid())
  recipeId    String
  recipe      Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@unique([recipeId, userId])
  @@map("recipe_favorites")
}

model RecipeTag {
  id          String   @id @default(uuid())
  recipeId    String
  recipe      Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  tag         String

  @@map("recipe_tags")
}

model MealPlanRecipe {
  id          String   @id @default(uuid())
  mealPlanId  String
  mealPlan    MealPlan @relation(fields: [mealPlanId], references: [id], onDelete: Cascade)
  recipeId    String
  recipe      Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  dayNumber   Int
  mealType    String   // breakfast, lunch, dinner, snack

  @@map("meal_plan_recipes")
}

model ShoppingList {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name            String
  description     String?  @db.Text
  status          String   @default("pending") // pending, inProgress, completed, archived
  budget          Decimal? @db.Decimal(10, 2)
  totalEstimated  Decimal? @db.Decimal(10, 2)
  totalReal       Decimal? @db.Decimal(10, 2)
  targetDate      DateTime? @db.Date
  completedAt     DateTime?
  isFromMealPlan  Boolean  @default(false)
  mealPlanId      String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt @default(now())
  items           ShoppingListItem[]
  sharedWith      ShoppingListShare[]
  purchases       PurchaseHistory[]

  @@map("shopping_lists")
}

model ShoppingListItem {
  id              String   @id @default(uuid())
  shoppingListId  String
  shoppingList    ShoppingList @relation(fields: [shoppingListId], references: [id], onDelete: Cascade)
  foodItemId      String?
  foodItem        FoodItem? @relation(fields: [foodItemId], references: [id])
  name            String
  category        String   // proteins, dairy, grains, fruits, vegetables, legumes, nuts, spices, supplements, beverages, snacks, frozen, bakery, pantry
  subcategory     String?
  quantity        Decimal  @db.Decimal(10, 2)
  unit            String   // g, kg, ml, L, units, pieces
  estimatedPrice  Decimal? @db.Decimal(10, 2)
  realPrice       Decimal? @db.Decimal(10, 2)
  brand           String?
  notes           String?  @db.Text
  isPurchased     Boolean  @default(false)
  purchasedAt     DateTime?
  assignedTo      String?  // userId para listas compartidas
  position        Int      @default(0) // orden en la lista
  store           String?  // tienda donde comprar
  barcode         String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt @default(now())

  @@map("shopping_list_items")
}

model PantryItem {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  foodItemId      String?
  foodItem        FoodItem? @relation(fields: [foodItemId], references: [id])
  name            String
  category        String
  quantity        Decimal  @db.Decimal(10, 2)
  unit            String
  purchaseDate    DateTime? @db.Date
  expirationDate  DateTime? @db.Date
  location        String?  // nevera, despensa, congelador
  minStock        Decimal? @db.Decimal(10, 2)
  isLowStock      Boolean  @default(false)
  isExpired       Boolean  @default(false)
  notes           String?  @db.Text
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt @default(now())

  @@map("pantry_items")
}

model ShoppingListShare {
  id              String   @id @default(uuid())
  shoppingListId  String
  shoppingList    ShoppingList @relation(fields: [shoppingListId], references: [id], onDelete: Cascade)
  sharedWithUserId String
  sharedWithUser  User     @relation(fields: [sharedWithUserId], references: [id])
  permission      String   // view, edit, admin
  accepted        Boolean  @default(false)
  sharedAt        DateTime @default(now())
  acceptedAt      DateTime?

  @@map("shopping_list_shares")
}

model Store {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name            String
  address         String?  @db.Text
  location        Json?    // {lat: number, lng: number}
  isFavorite      Boolean  @default(false)
  category        String?  // supermercado, mercado, tienda especializada
  notes           String?  @db.Text
  createdAt       DateTime @default(now())

  @@map("stores")
}

model PurchaseHistory {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  shoppingListId  String?
  shoppingList    ShoppingList? @relation(fields: [shoppingListId], references: [id])
  purchaseDate    DateTime @db.Date
  store           String?
  totalAmount     Decimal  @db.Decimal(10, 2)
  itemsCount      Int
  paymentMethod   String?  // cash, card, transfer
  receipt         String?  // URL de foto del recibo
  notes           String?  @db.Text
  createdAt       DateTime @default(now())

  @@map("purchase_histories")
}

model ShoppingReminder {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title           String
  shoppingListId  String?
  reminderType    String   // shoppingDay, lowStock, expiration
  dateTime        DateTime
  daysOfWeek      Int[]    // [0,1,2,3,4,5,6]
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())

  @@map("shopping_reminders")
}

model NutritionReminder {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  reminderType String
  title       String
  time        String   // formato "HH:MM"
  daysOfWeek  Int[]    // [0,1,2,3,4,5,6] para días de semana
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@map("nutrition_reminders")
}

model TrainingProfile {
  id                  String   @id @default(uuid())
  userId              String   @unique
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  experienceLevel     String   // beginner, intermediate, advanced, elite
  trainingYears       Int
  daysPerWeek         Int
  sessionDurationMin  Int
  preferredSplit      String   // fullbody, upperLower, pushPullLegs, broSplit, powerbuilding
  equipmentAvailable  String[]
  injuries            String?  @db.Text
  goals               String[]
  currentWeightKg     Decimal  @db.Decimal(5, 2)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@map("training_profiles")
}

model Exercise {
  id              String   @id @default(uuid())
  name            String
  category        String   // chest, back, legs, shoulders, arms, core, cardio
  type            String   // compound, isolation, machine, freeWeight, bodyweight
  equipment       String[]
  difficulty      String   // beginner, intermediate, advanced
  instructions    String?  @db.Text
  videoUrl        String?
  imageUrl        String?
  primaryMuscles  String[]
  secondaryMuscles String[]
  tips            String?  @db.Text
  commonMistakes  String?  @db.Text
  variations      String[]
  isCustom        Boolean  @default(false)
  creatorId       String?
  user            User?    @relation(fields: [creatorId], references: [id], onDelete: SetNull)
  isVerified      Boolean  @default(false)
  createdAt       DateTime @default(now())
  workoutExercises WorkoutExercise[]
  planExercises   PlanExercise[]
  trainingProgress TrainingProgress[]
  personalRecords  PersonalRecord[]

  @@map("exercises")
}

model TrainingPlan {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name            String
  description     String?  @db.Text
  splitType       String   // fullbody, upperLower, pushPullLegs, broSplit, powerbuilding
  durationWeeks   Int
  daysPerWeek     Int
  goal            String   // strength, hypertrophy, endurance, power
  experienceLevel String
  isActive        Boolean  @default(false)
  startDate       DateTime? @db.Date
  endDate         DateTime? @db.Date
  currentWeek     Int      @default(1)
  isPredefined    Boolean  @default(false)
  createdAt       DateTime @default(now())
  weeks           TrainingWeek[]

  @@map("training_plans")
}

model TrainingWeek {
  id              String   @id @default(uuid())
  trainingPlanId  String
  trainingPlan    TrainingPlan @relation(fields: [trainingPlanId], references: [id], onDelete: Cascade)
  weekNumber      Int
  focus           String?  // volume, intensity, deload, peak
  days            TrainingDay[]

  @@map("training_weeks")
}

model TrainingDay {
  id              String   @id @default(uuid())
  trainingWeekId  String
  trainingWeek    TrainingWeek @relation(fields: [trainingWeekId], references: [id], onDelete: Cascade)
  dayNumber       Int
  name            String   // Día de Pierna, Push Day, etc.
  focus           String   // legs, push, pull, upper, lower, fullbody
  estimatedDurationMin Int
  exercises       PlanExercise[]
  workoutLogs     WorkoutLog[]

  @@map("training_days")
}

model PlanExercise {
  id              String   @id @default(uuid())
  trainingDayId   String
  trainingDay     TrainingDay @relation(fields: [trainingDayId], references: [id], onDelete: Cascade)
  exerciseId      String
  exercise        Exercise @relation(fields: [exerciseId], references: [id])
  order           Int
  sets            Int
  reps            String   // "8-10", "5", "AMRAP"
  weightKg        Decimal? @db.Decimal(5, 2)
  restSeconds     Int
  tempo           String?  // "3-1-2-0"
  rpe             Int?     // 1-10
  notes           String?  @db.Text

  @@map("plan_exercises")
}

model WorkoutLog {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  trainingDayId   String?
  trainingDay     TrainingDay? @relation(fields: [trainingDayId], references: [id])
  workoutDate     DateTime @db.Date
  startTime       DateTime
  endTime         DateTime?
  durationMinutes Int?
  totalVolume     Decimal? @db.Decimal(10, 2)
  averageRPE      Decimal? @db.Decimal(3, 2)
  energyLevel     Int?     // 1-5
  moodBefore      String?
  moodAfter       String?
  notes           String?  @db.Text
  isCompleted     Boolean  @default(false)
  exercises       WorkoutExercise[]
  createdAt       DateTime @default(now())

  @@map("workout_logs")
}

model WorkoutExercise {
  id              String   @id @default(uuid())
  workoutLogId    String
  workoutLog      WorkoutLog @relation(fields: [workoutLogId], references: [id], onDelete: Cascade)
  exerciseId      String
  exercise        Exercise @relation(fields: [exerciseId], references: [id])
  order           Int
  sets            Int
  repsCompleted   String   // "10, 10, 8"
  weightKg        Decimal  @db.Decimal(5, 2)
  restSeconds     Int?
  rpe             Int?     // 1-10
  isPR            Boolean  @default(false)
  notes           String?  @db.Text

  @@map("workout_exercises")
}

model TrainingProgress {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  exerciseId      String
  exercise        Exercise @relation(fields: [exerciseId], references: [id])
  loggedDate      DateTime @db.Date
  oneRepMax       Decimal? @db.Decimal(5, 2)
  estimatedOneRepMax Decimal? @db.Decimal(5, 2)
  volumeTotal     Decimal? @db.Decimal(10, 2)
  bestSet         String?  // "100kg x 5"
  createdAt       DateTime @default(now())

  @@unique([userId, exerciseId, loggedDate])
  @@map("training_progress")
}

model Achievement {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type            String
  title           String
  description     String
  icon            String?
  earnedAt        DateTime @default(now())
  metadata        Json?
  @@map("achievements")
}

model TrainingReminder {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  reminderType    String   // workout, deload, progression
  title           String
