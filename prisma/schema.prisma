  @@unique([date, category, channel])
  @@map("notification_analytics")
}

// ─── Social Feed ────────────────────────────────────────────────────────────

model SocialPost {
  id          String        @id @default(uuid())
  userId      String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  content     String
  imageUrl    String?
  category    String        @default("general") // general, nutrition, training, progress
  likesCount  Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  likes       PostLike[]
  comments    PostComment[]

  @@map("social_posts")
  @@index([userId])
  @@index([createdAt])
}

model PostLike {
  id        String     @id @default(uuid())
  postId    String
  post      SocialPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime   @default(now())

  @@unique([postId, userId])
  @@map("post_likes")
}

model PostComment {
  id        String     @id @default(uuid())
  postId    String
  post      SocialPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   String
  createdAt DateTime   @default(now())

  @@map("post_comments")
  @@index([postId])
}

model UserFollow {
  id          String   @id @default(uuid())
  followerId  String
  follower    User     @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  followingId String
  following   User     @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@unique([followerId, followingId])
  @@map("user_follows")
}

// ─── Body Measurements ──────────────────────────────────────────────────────

model BodyMeasurement {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date         DateTime @db.Date
  weightKg     Decimal? @db.Decimal(5, 2)
  bodyFatPct   Decimal? @db.Decimal(5, 2)
  muscleMassPct Decimal? @db.Decimal(5, 2)
  chestCm      Decimal? @db.Decimal(5, 1)
  waistCm      Decimal? @db.Decimal(5, 1)
  hipsCm       Decimal? @db.Decimal(5, 1)
  armCm        Decimal? @db.Decimal(5, 1)
  thighCm      Decimal? @db.Decimal(5, 1)
  notes        String?
  createdAt    DateTime @default(now())

  @@map("body_measurements")
  @@index([userId, date])
}

// ─── Phase 3: Subscriptions & Payments ──────────────────────────────────────

model UserSubscription {
  id                    String   @id @default(uuid())
  userId                String   @unique
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  planId                String   // free, pro, premium
  stripeSubscriptionId  String?  @unique
  stripeCustomerId      String?
  status                String   @default("active") // active, canceled, past_due, trialing, incomplete
  currentPeriodStart    DateTime?
  currentPeriodEnd      DateTime?
  cancelAtPeriodEnd     Boolean  @default(false)
  canceledAt            DateTime?
  trialStart            DateTime?
  trialEnd              DateTime?
  couponCode            String?
  discountPercent       Int?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@map("user_subscriptions")
  @@index([status])
  @@index([planId])
}

model Payment {
  id                    String   @id @default(uuid())
  userId                String
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  stripePaymentIntentId String?  @unique
  stripeInvoiceId       String?
  amount                Int      // en centavos
  currency              String   @default("usd")
  status                String   // succeeded, failed, pending, refunded
  description           String?
  receiptUrl            String?
  planId                String?
  billingPeriod         String?  // monthly, yearly
  metadata              Json?
  failureReason         String?
  refundedAt            DateTime?
  createdAt             DateTime @default(now())

  @@map("payments")
  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

// ─── Phase 3: Audit Logs ─────────────────────────────────────────────────────

model AuditLog {
  id           String   @id @default(uuid())
  userId       String?
  user         User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action       String   // user.login, payment.created, admin.user.banned, etc.
  resourceType String?  // User, Payment, Workout, etc.
  resourceId   String?
  oldValue     Json?
  newValue     Json?
  ipAddress    String?
  userAgent    String?
  metadata     Json?
  createdAt    DateTime @default(now())

  @@map("audit_logs")
  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@index([resourceType, resourceId])
}

// ─── Phase 3: Support Tickets ────────────────────────────────────────────────

model SupportTicket {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject      String
  body         String   @db.Text
  status       String   @default("open") // open, in_progress, resolved, closed
  priority     String   @default("medium") // low, medium, high, urgent
  category     String   @default("general") // general, billing, technical, account
  assignedToId String?
  resolvedAt   DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  replies      SupportTicketReply[]

  @@map("support_tickets")
  @@index([userId])
  @@index([status])
  @@index([priority])
}

model SupportTicketReply {
  id       String        @id @default(uuid())
  ticketId String
  ticket   SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  userId   String
  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  body     String        @db.Text
  isStaff  Boolean       @default(false)
  createdAt DateTime     @default(now())

  @@map("support_ticket_replies")
  @@index([ticketId])
}

// ─── Phase 4: AI + Wearables ─────────────────────────────────────────────────

model AIRecommendation {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        String   // meal_plan, workout, coaching, food_scan, insight
  prompt      String   @db.Text
  response    String   @db.Text
  metadata    Json?    // tokens used, model, confidence, etc.
  tokensUsed  Int?
  modelUsed   String?  // gpt-4o, gpt-3.5-turbo, claude-3, etc.
  rating      Int?     // user feedback 1-5
  ratingNote  String?
  isBookmarked Boolean @default(false)
  createdAt   DateTime @default(now())

  @@map("ai_recommendations")
  @@index([userId])
  @@index([type])
  @@index([createdAt])
}

model ChatMessage {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionId String   // agrupa mensajes de una conversación
  role      String   // user | assistant | system
  content   String   @db.Text
  metadata  Json?    // function calls, attachments, etc.
  createdAt DateTime @default(now())

  @@map("chat_messages")
  @@index([userId, sessionId])
  @@index([userId, createdAt])
}

model WearableConnection {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider     String   // fitbit | garmin | google_fit | healthkit | whoop | oura
  accessToken  String?  @db.Text
  refreshToken String?  @db.Text
  expiresAt    DateTime?
  scopes       String[]
  isActive     Boolean  @default(true)
  lastSync     DateTime?
  metadata     Json?    // extra fields per provider
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([userId, provider])
  @@map("wearable_connections")
  @@index([userId])
}

// ─── Phase 5: Enterprise + Multi-tenant + Billing + Compliance + Growth ──────

model Organization {
  id              String   @id @default(uuid())
  name            String
  slug            String   @unique
  domain          String?  @unique
  plan            String   @default("business")
  ownerId         String
  contactEmail    String
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  trialEndsAt     DateTime?
  contractEndsAt  DateTime?
  monthlyBudget   Decimal? @db.Decimal(12, 2)
  currency        String   @default("USD")
  billingEmail    String?
  taxId           String?
  allowOverage    Boolean  @default(false)

  whiteLabelConfig  WhiteLabelConfig?
  members           OrgMember[]
  apiKeys           APIKey[]
  usageRecords      UsageRecord[]
  invoices          Invoice[]
  complianceAudits  ComplianceAudit[]
  ssoConfig         SSOConfig?
  abTests           ABTest[]
  dataResidencyRule DataResidencyRule?

  @@map("organizations")
  @@index([slug])
}

model OrgMember {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  role           String       @default("member")
  invitedAt      DateTime     @default(now())
  joinedAt       DateTime?
  isActive       Boolean      @default(true)

  @@unique([organizationId, userId])
  @@map("org_members")
  @@index([organizationId])
  @@index([userId])
}

model WhiteLabelConfig {
  id             String       @id @default(uuid())
  organizationId String       @unique
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  appName        String       @default("WacoPro")
  primaryColor   String       @default("#6c63ff")
  secondaryColor String       @default("#48bb78")
  accentColor    String?
  logoUrl        String?
  faviconUrl     String?
  customDomain   String?
  customCSS      String?      @db.Text
  emailFromName  String?
  emailFromAddr  String?
  supportEmail   String?
  hideWacoProBranding Boolean @default(false)
  metadata       Json?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@map("white_label_configs")
}

model SSOConfig {
  id             String       @id @default(uuid())
  organizationId String       @unique
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  provider       String
  entityId       String?
  ssoUrl         String?
  x509Cert       String?      @db.Text
  attributeMap   Json?
  scimEnabled    Boolean      @default(false)
  scimToken      String?
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@map("sso_configs")
}

model APIKey {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  keyHash        String       @unique
  keyPrefix      String
  scopes         String[]
  rateLimit      Int          @default(1000)
  isActive       Boolean      @default(true)
  expiresAt      DateTime?
  lastUsedAt     DateTime?
  createdAt      DateTime     @default(now())
  usageRecords   UsageRecord[]

  @@map("api_keys")
  @@index([keyHash])
  @@index([organizationId])
}

model UsageRecord {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  apiKeyId       String?
  apiKey         APIKey?      @relation(fields: [apiKeyId], references: [id])
  userId         String?
  endpoint       String
  method         String       @default("POST")
  category       String
  quantity       Decimal      @default(1) @db.Decimal(12, 4)
  unitCost       Decimal      @default(0) @db.Decimal(12, 6)
  totalCost      Decimal      @default(0) @db.Decimal(12, 4)
  responseMs     Int?
  statusCode     Int?
  metadata       Json?
  billedAt       DateTime?
  timestamp      DateTime     @default(now())

  @@map("usage_records")
  @@index([organizationId, timestamp])
  @@index([billedAt])
}

model Invoice {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invoiceNumber  String       @unique
  periodStart    DateTime
  periodEnd      DateTime
  status         String       @default("draft")
  subtotal       Decimal      @db.Decimal(12, 2)
  tax            Decimal      @default(0) @db.Decimal(12, 2)
  total          Decimal      @db.Decimal(12, 2)
  currency       String       @default("USD")
  lineItems      Json
  pdfUrl         String?
  stripeInvoiceId String?
  dueDate        DateTime
  paidAt         DateTime?
  voidedAt       DateTime?
  notes          String?      @db.Text
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@map("invoices")
  @@index([organizationId, status])
}

model ComplianceAudit {
  id             String        @id @default(uuid())
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  framework      String
  controlId      String
  controlName    String
  status         String
  executedAt     DateTime      @default(now())
  executedBy     String        @default("automated")
  evidence       Json
  findings       Json?
  remediation    String?       @db.Text
  dueDate        DateTime?
  resolvedAt     DateTime?

  @@map("compliance_audits")
  @@index([framework, status])
}

model DataResidencyRule {
  id             String       @id @default(uuid())
  organizationId String       @unique
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  allowedRegions String[]
  primaryRegion  String       @default("us-east-1")
  blockCrossRegion Boolean    @default(false)
  piiFields      String[]
  retentionDays  Int          @default(2555)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@map("data_residency_rules")
}

model ABTest {
  id             String        @id @default(uuid())
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  name           String
  description    String?
  status         String        @default("draft")
  variants       Json
  targetAudience Json?
  primaryMetric  String        @default("conversion_rate")
  startedAt      DateTime?
  endedAt        DateTime?
  winnerVariant  String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  exposures      ABTestExposure[]

  @@map("ab_tests")
  @@index([status])
}

model ABTestExposure {
  id          String   @id @default(uuid())
  testId      String
  test        ABTest   @relation(fields: [testId], references: [id], onDelete: Cascade)
  userId      String
  variant     String
  exposedAt   DateTime @default(now())
  converted   Boolean  @default(false)
  convertedAt DateTime?
  metadata    Json?

  @@unique([testId, userId])
  @@map("ab_test_exposures")
  @@index([testId, variant])
}

// ─── Phase 6: Home Fitness Platform ──────────────────────────────────────────

model Trainer {
  id              String    @id @default(uuid())
  userId          String    @unique
  bio             String?   @db.Text
  specialties     String[]
  certifications  String[]
  experienceYears Int       @default(0)
  rating          Float     @default(0)
  reviewCount     Int       @default(0)
  sessionRate     Decimal?  @db.Decimal(10, 2) // per session price
  monthlyRate     Decimal?  @db.Decimal(10, 2)
  isAvailable     Boolean   @default(true)
  languages       String[]
  timezone        String    @default("UTC")
  avatarUrl       String?
  introVideoUrl   String?
  instagramHandle String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  virtualClasses   VirtualClass[]
  coachingSessions CoachingSession[]

  @@map("trainers")
}

model ClassCategory {
  id          String   @id @default(uuid())
  name        String   @unique
  slug        String   @unique
  description String?
  iconName    String?
  colorHex    String   @default("#6c63ff")
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  virtualClasses VirtualClass[]

  @@map("class_categories")
}

model VirtualClass {
  id              String    @id @default(uuid())
  title           String
  description     String?   @db.Text
  instructorId    String
  categoryId      String
  difficulty      String    // beginner, intermediate, advanced
  durationMinutes Int
  equipmentNeeded String[]
  caloriesBurned  Int?
  thumbnailUrl    String?
  // On-demand fields
  videoUrl        String?   // Mux/Vimeo/S3 playback URL
  videoAssetId    String?   // provider asset ID
  drmEnabled      Boolean   @default(false)
  // Live session fields
  isLive          Boolean   @default(false)
  liveUrl         String?   // Zoom/YouTube/Jitsi link
  scheduledAt     DateTime?
  recordingUrl    String?
  replayExpiresAt DateTime?
  // Meta
  isActive        Boolean   @default(true)
  isFeatured      Boolean   @default(false)
  tags            String[]
  rating          Float     @default(0)
  reviewCount     Int       @default(0)
  enrollmentCount Int       @default(0)
  viewCount       Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  instructor   Trainer        @relation(fields: [instructorId], references: [id])
  category     ClassCategory  @relation(fields: [categoryId], references: [id])
  enrollments  ClassEnrollment[]
  reviews      ClassReview[]

  @@map("virtual_classes")
  @@index([instructorId])
  @@index([categoryId])
  @@index([difficulty])
  @@index([isLive, scheduledAt])
  @@index([isActive, isFeatured])
}

model ClassEnrollment {
  id          String        @id @default(uuid())
  userId      String
  classId     String
  enrolledAt  DateTime      @default(now())
  completed   Boolean       @default(false)
  completedAt DateTime?
  watchedSeconds Int        @default(0)  // progress for on-demand
  lastWatchedAt  DateTime?

  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  class       VirtualClass  @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@unique([userId, classId])
  @@map("class_enrollments")
  @@index([userId])
  @@index([classId])
}

model ClassReview {
  id        String       @id @default(uuid())
  userId    String
  classId   String
  rating    Int          // 1-5
  comment   String?      @db.Text
  createdAt DateTime     @default(now())

  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  class     VirtualClass @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@unique([userId, classId])
  @@map("class_reviews")
  @@index([classId])
}

model WorkoutProgram {
  id              String    @id @default(uuid())
  name            String
  description     String?   @db.Text
  shortDescription String?
  category        String    // weight_loss, muscle_building, strength, endurance, flexibility, hiit, yoga, beginner
  difficulty      String    // beginner, intermediate, advanced
  durationWeeks   Int
  workoutsPerWeek Int
  equipmentNeeded String[]
  goal            String
  targetGender    String    @default("all") // all, male, female
  minAge          Int?
  maxAge          Int?
  thumbnailUrl    String?
  previewVideoUrl String?
  price           Float     @default(0)
  isFree          Boolean   @default(false)
  isFeatured      Boolean   @default(false)
  isActive        Boolean   @default(true)
  enrollmentCount Int       @default(0)
  rating          Float     @default(0)
  reviewCount     Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  weeks       ProgramWeek[]
  enrollments ProgramEnrollment[]

  @@map("workout_programs")
  @@index([category])
  @@index([difficulty])
  @@index([goal])
  @@index([isActive, isFeatured])
}

model ProgramWeek {
  id        String         @id @default(uuid())
  programId String
  program   WorkoutProgram @relation(fields: [programId], references: [id], onDelete: Cascade)
  weekNumber Int
  theme     String?        // e.g. "Foundation", "Intensity", "Deload"
  days      ProgramDay[]

  @@map("program_weeks")
  @@index([programId])
}

model ProgramDay {
  id           String      @id @default(uuid())
  weekId       String
  week         ProgramWeek @relation(fields: [weekId], references: [id], onDelete: Cascade)
  dayNumber    Int         // 1-7
  title        String
  isRestDay    Boolean     @default(false)
  durationMin  Int?
  exercises    Json        // [{exerciseId, sets, reps, rest, notes}]
  virtualClassId String?   // optional linked class

  @@map("program_days")
  @@index([weekId])
}

model ProgramEnrollment {
  id              String         @id @default(uuid())
  userId          String
  programId       String
  enrolledAt      DateTime       @default(now())
  currentWeek     Int            @default(1)
  currentDay      Int            @default(1)
  progressPercent Float          @default(0)
  completed       Boolean        @default(false)
  completedAt     DateTime?
  lastActivityAt  DateTime?

  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  program WorkoutProgram @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@unique([userId, programId])
  @@map("program_enrollments")
  @@index([userId])
  @@index([programId])
}

model CoachingSession {
  id           String    @id @default(uuid())
  coachId      String
  userId       String
  scheduledAt  DateTime
  durationMin  Int       @default(60)
  type         String    // consultation, check_in, form_check, nutrition, custom
  meetingUrl   String?   // Zoom/Google Meet link
  status       String    @default("scheduled") // scheduled, completed, cancelled, no_show
  coachNotes   String?   @db.Text
  clientNotes  String?   @db.Text
  recordingUrl String?
  priceCents   Int?
  paymentStatus String   @default("pending") // pending, paid, refunded
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  coach   Trainer @relation(fields: [coachId], references: [id])
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("coaching_sessions")
  @@index([coachId])
  @@index([userId])
  @@index([scheduledAt])
  @@index([status])
}

model ProgressPhoto {
  id          String    @id @default(uuid())
  userId      String
  photoUrl    String
  angle       String    @default("front") // front, back, side_left, side_right
  takenAt     DateTime
  weightKg    Float?
  bodyFatPct  Float?
  notes       String?   @db.Text
  isPrivate   Boolean   @default(true)
  createdAt   DateTime  @default(now())

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("progress_photos")
  @@index([userId, takenAt])
}

model FitnessChallenge {
  id                  String    @id @default(uuid())
  name                String
  description         String?   @db.Text
  type                String    // workout, step, weight_loss, strength, streak, nutrition, flexibility
  startDate           DateTime
  endDate             DateTime
  goal                String    @db.Text
  unit                String    // sessions, steps, kg, reps
  targetValue         Float
  isTeam              Boolean   @default(false)
  maxParticipants     Int?
  currentParticipants Int       @default(0)
  prizeDescription    String?
  badgeImageUrl       String?
  isActive            Boolean   @default(true)
  isPublic            Boolean   @default(true)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  participants FitnessChallengeParticipant[]

  @@map("fitness_challenges")
  @@index([startDate, endDate])
  @@index([isActive, isPublic])
}

model FitnessChallengeParticipant {
  id          String           @id @default(uuid())
  challengeId String
  userId      String
  joinedAt    DateTime         @default(now())
  progress    Float            @default(0)
  completed   Boolean          @default(false)
  completedAt DateTime?
  rank        Int?
  lastCheckin DateTime?

  challenge FitnessChallenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([challengeId, userId])
  @@map("fitness_challenge_participants")
  @@index([challengeId])
  @@index([userId])
}

model VideoCategory {
  id          String   @id @default(uuid())
  name        String   @unique
  slug        String   @unique
  description String?
  iconName    String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  videos      OnDemandVideo[]

  @@map("video_categories")
}

model OnDemandVideo {
  id              String        @id @default(uuid())
  categoryId      String
  title           String
  description     String?       @db.Text
  instructorName  String?
  thumbnailUrl    String?
  videoUrl        String?       // signed/CDN URL
  videoAssetId    String?       // Mux/Vimeo asset ID
  durationSeconds Int           @default(0)
  difficulty      String        @default("beginner")
  equipmentNeeded String[]
  muscleGroups    String[]
  caloriesBurned  Int?
  tags            String[]
  language        String        @default("es")
  isActive        Boolean       @default(true)
  isFeatured      Boolean       @default(false)
  viewCount       Int           @default(0)
  likeCount       Int           @default(0)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  category       VideoCategory    @relation(fields: [categoryId], references: [id])
  watchHistory   UserWatchHistory[]

  @@map("on_demand_videos")
  @@index([categoryId])
  @@index([difficulty])
  @@index([isActive, isFeatured])
}

model UserWatchHistory {
  id             String        @id @default(uuid())
  userId         String
  videoId        String
  watchedSeconds Int           @default(0)
  totalSeconds   Int           @default(0)
  completedAt    DateTime?
  lastWatchedAt  DateTime      @default(now())
  liked          Boolean       @default(false)

  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  video          OnDemandVideo @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@unique([userId, videoId])
  @@map("user_watch_history")
  @@index([userId])
  @@index([videoId])
}

// ─── Phase 7 — New Features ─────────────────────────────────────────────────

// USER SETTINGS — Tema, idioma, preferencias
model UserSettings {
  id           String   @id @default(uuid())
  userId       String   @unique
  theme        String   @default("dark")   // dark, light, auto
  language     String   @default("es")     // es, en, pt
  weightUnit   String   @default("kg")     // kg, lbs
  heightUnit   String   @default("cm")     // cm, ft
  dateFormat   String   @default("DD/MM/YYYY")
  notifications Json    @default("{}")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_settings")
}

// PERIODIZED PLANS — Planes de entrenamiento periodizados
model PeriodizedPlan {
  id            String   @id @default(uuid())
  userId        String
  name          String
  type          String   // hypertrophy, strength, endurance, power, cutting
  durationWeeks Int
  difficulty    String   // beginner, intermediate, advanced
  goal          String
  startDate     DateTime?
  completed     Boolean  @default(false)
  completedAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  phases        PlanPhase[]
  cycles        PlanCycle[]

  @@map("periodized_plans")
  @@index([userId])
}

model PlanPhase {
  id        String   @id @default(uuid())
  planId    String
  name      String
  type      String   // adaptation, hypertrophy, strength, power, deload
  weekStart Int
  weekEnd   Int
  volume    String   // low, medium, high
  intensity String   // low, medium, high
  focus     String
  workouts  Json     @default("[]")

  plan      PeriodizedPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@map("plan_phases")
}

model PlanCycle {
  id         String   @id @default(uuid())
  planId     String
  weekNumber Int
  name       String
  workouts   Json     @default("[]")
  completed  Boolean  @default(false)

  plan       PeriodizedPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@map("plan_cycles")
}

// FORM CHECK — Análisis de forma con IA
model FormCheckSession {
  id           String   @id @default(uuid())
  userId       String
  exercise     String   // squat, bench, deadlift, ohp, pullup, row
  videoUrl     String?
  score        Int?     // 0-100
  feedback     Json     @default("[]")
  angles       Json     @default("{}")
  errors       Json     @default("[]")
  recommendations Json  @default("[]")
  createdAt    DateTime @default(now())

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("form_check_sessions")
  @@index([userId])
}

// RECOVERY METRICS — Métricas avanzadas de recuperación (HRV + sueño + fatiga)
model RecoveryMetric {
  id               String   @id @default(uuid())
  userId           String
  date             DateTime @db.Date
  hrv              Float?
  restingHeartRate Int?
  sleepHours       Float?
  sleepQuality     Int?     // 1-10
  fatigueLevel     Int?     // 1-10
  stressLevel      Int?     // 1-10
  muscleSoreness   Int?     // 1-10
  energyLevel      Int?     // 1-10
  recoveryScore    Int?     // 0-100
  notes            String?
  createdAt        DateTime @default(now())

  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@map("recovery_metrics")
  @@index([userId])
}

// MEAL DELIVERY — Integración con servicios de delivery
model MealDeliveryOrder {
  id            String   @id @default(uuid())
  userId        String
  restaurantName String
  restaurantId  String?
  provider      String   @default("manual") // ubereats, rappi, didifood, manual
  status        String   @default("pending") // pending, confirmed, preparing, delivered, cancelled
  totalCalories Int?
  totalProteinG Float?
  totalCarbsG   Float?
  totalFatG     Float?
  totalPrice    Float?
  notes         String?
  orderedAt     DateTime @default(now())
  deliveredAt   DateTime?
  createdAt     DateTime @default(now())

  user          User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  items         MealDeliveryItem[]

  @@map("meal_delivery_orders")
  @@index([userId])
}

model MealDeliveryItem {
  id          String            @id @default(uuid())
  orderId     String
  name        String
  quantity    Int               @default(1)
  calories    Int?
  proteinG    Float?
  carbsG      Float?
  fatG        Float?
  price       Float?

  order       MealDeliveryOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("meal_delivery_items")
}

// BACKUP — Respaldo de datos
model Backup {
  id        String   @id @default(uuid())
  userId    String
  type      String   @default("manual") // manual, automatic
  provider  String   @default("local")  // local, s3, google_drive, dropbox
  filePath  String
  fileSize  Int      @default(0)
  status    String   @default("success") // success, failed, pending
  encrypted Boolean  @default(true)
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("backups")
  @@index([userId])
}

// EXERCISE VIDEOS — Videos tutoriales por ejercicio
model ExerciseVideo {
  id           String   @id @default(uuid())
  exerciseId   String?
  exerciseName String
  url          String
  provider     String   @default("youtube") // youtube, vimeo, cloudinary, mux
  quality      String   @default("720p")    // 720p, 1080p
  angle        String   @default("front")   // front, side, top
  durationSec  Int      @default(0)
  thumbnailUrl String?
  captions     Boolean  @default(false)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  @@map("exercise_videos")
  @@index([exerciseId])
}

// SHOP PRODUCTS — Catálogo de suplementos
model ShopProduct {
  id           String   @id @default(uuid())
  name         String
  brand        String?
  category     String   // protein, creatine, preworkout, vitamins, etc.
  description  String?
  imageUrl     String?
  price        Float?
  currency     String   @default("USD")
  rating       Float?
  reviewCount  Int      @default(0)
  affiliateUrl String?
  isActive     Boolean  @default(true)
  tags         String[]
  macros       Json?    // { protein, carbs, fat, calories per serving }
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("shop_products")
  @@index([category])
  @@index([isActive])
}

// IMPORT HISTORY — Historial de importaciones
model ImportHistory {
  id          String   @id @default(uuid())
  userId      String
  source      String   // myfitnesspal, strong, fitnotes, googlefit, applehealth, csv
  status      String   @default("pending") // pending, processing, completed, failed
  recordsImported Int  @default(0)
  recordsFailed   Int  @default(0)
  errorLog    String?  @db.Text
  filePath    String?
  createdAt   DateTime @default(now())
  completedAt DateTime?

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("import_histories")
  @@index([userId])
}
