# ==========================================
# SERVIDOR
# ==========================================
PORT=3000
NODE_ENV=development
APP_URL=http://localhost:3000

# ==========================================
# BASE DE DATOS - SUPABASE
# ==========================================
# Puerto 6543 (PgBouncer) — Para la app en runtime
DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# Puerto 5432 (Conexión directa) — SOLO para migraciones Prisma
# Host diferente: db.PROJECT_REF.supabase.co
DIRECT_URL="postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres"

# ==========================================
# REDIS — Cache y queues (opcional en dev)
# ==========================================
REDIS_HOST=localhost
REDIS_PORT=6379
# Upstash (recomendado para producción):
# REDIS_URL=redis://default:PASSWORD@HOST.upstash.io:6379

# ==========================================
# JWT
# ==========================================
JWT_SECRET=cambia_esto_por_algo_muy_secreto_min_32_chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=otro_secret_diferente_para_refresh_tokens
JWT_REFRESH_EXPIRES_IN=30d

# ==========================================
# STRIPE — Pagos y suscripciones
# ==========================================
# Claves en: dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_XXXXXXXXXXXXXXXXXXXXXXXXXXXX
STRIPE_PUBLISHABLE_KEY=pk_test_XXXXXXXXXXXXXXXXXXXXXXXXXXXX
# Webhook secret en: dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXXXXXXXXXXXXXXXXX
# IDs de precios (crear en dashboard.stripe.com/products)
STRIPE_PRICE_PRO=price_XXXXXXXXXXXXXXXXXXXX
STRIPE_PRICE_PREMIUM=price_XXXXXXXXXXXXXXXXXXXX

# ==========================================
# EMAIL — SendGrid
# ==========================================
# API key en: app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG.XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
FROM_EMAIL=noreply@tudominio.com
FROM_NAME=WacoPro Fitness

# ==========================================
# SUPABASE SDK
# ==========================================
SUPABASE_URL=https://PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ==========================================
# CORS
# ==========================================
CORS_ORIGIN=http://localhost:3000

# ==========================================
# MONITORING (opcional)
# ==========================================
SENTRY_DSN=https://XXXX@oXXX.ingest.sentry.io/XXXX
GA_MEASUREMENT_ID=G-XXXXXXXXXX
LOG_LEVEL=info

# ==========================================
# FILE UPLOAD
# ==========================================
MAX_FILE_SIZE=5242880
UPLOAD_PATH=./uploads

# ==========================================
# OPENAI — AI Coach features (Phase 4)
# ==========================================
OPENAI_API_KEY=sk-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
OPENAI_MODEL=gpt-4o-mini

# ==========================================
# FIREBASE — Push notifications
# ==========================================
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nXXX\n-----END PRIVATE KEY-----\n"

# ==========================================
# VIDEO HOSTING — Mux (Phase 6)
# ==========================================
MUX_TOKEN_ID=your-mux-token-id
MUX_TOKEN_SECRET=your-mux-token-secret

# ==========================================
# RATE LIMITING
# ==========================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=500

# ==========================================
# WACOCOACH — Agente de Voz IA (Phase 4)
# ==========================================
# Clave AES-256 para cifrado de datos de salud (32 bytes en hex = 64 chars)
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=generar_64_chars_hex_aqui_ver_instruccion_arriba_XXXXXXXXXXXXXXXX

# Edad mínima para usar la plataforma
MIN_USER_AGE=18

# Voz (Web Speech API — nativo del navegador, no requiere API keys externos)
VOICE_ENABLED=true
VOICE_LANGUAGE=es-CO
VOICE_FALLBACK_TO_TEXT=true

# Límite de mensajes por sesión de chat (evita conversaciones infinitas)
MAX_CONVERSATION_LENGTH=50
