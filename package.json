{
  "name": "serviciodeapps1",
  "version": "1.0.0",
  "description": "WacoPro Fitness API Backend",
  "main": "dist/server.js",
  "type": "commonjs",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "start": "node dist/server.js",
    "build": "tsc",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:push": "prisma db push",
    "seed": "ts-node prisma/seed.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:backend": "ts-node scripts/test-backend.ts",
    "test:supabase": "ts-node scripts/test-supabase.ts",
    "verify:migration": "npx ts-node scripts/verify-migration.ts",
    "queue:worker": "ts-node src/workers/queue.worker.ts",
    "vercel-build": "npx prisma generate && npm run build"
  },
  "keywords": [
    "fitness",
    "nutrition",
    "training",
    "api",
    "supabase",
    "prisma"
  ],
  "author": "WacoPro",
  "license": "ISC",
