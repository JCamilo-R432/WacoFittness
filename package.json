    "@supabase/supabase-js": "^2.39.7",
    "bcryptjs": "^2.4.3",
    "bull": "^4.12.2",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "express-rate-limit": "^7.2.0",
    "firebase-admin": "^13.7.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "openai": "^4.104.0",
    "otplib": "^12.0.1",
    "pino": "^8.19.0",
    "pino-http": "^9.0.0",
    "prom-client": "^15.1.0",
    "qrcode": "^1.5.3",
    "redis": "^5.11.0",
    "socket.io": "^4.8.3",
    "stripe": "^14.21.0",
    "winston": "^3.11.0",
    "zod": "^3.22.4"
